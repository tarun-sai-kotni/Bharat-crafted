;\n      let currentLi = this.closest('li');\n\n      while (currentLi) {\n\n        let currentLink = currentLi.querySelector(':scope > a');\n\n        if (currentLink) {\n          path.unshift({\n            title: currentLink.textContent.trim(),\n            url: currentLink.href\n          });\n        }\n\n        currentLi = currentLi.parentElement.closest('li');\n      }\n\n      localStorage.setItem(\n        'collection_breadcrumb',\n        JSON.stringify(path)\n      );\n\n    });\n\n  });\n\n});\n<\/script>\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n\n  const breadcrumb = JSON.parse(\n    localStorage.getItem('collection_breadcrumb')\n  );\n\n  if (!breadcrumb || !breadcrumb.length) {\n    return;\n  }\n\n  const currentCollectionUrl = window.location.pathname;\n\n  const lastItem = breadcrumb[breadcrumb.length - 1];\n\n  if (!lastItem.url.includes(currentCollectionUrl)) {\n    return;\n  }\n\n  let html = '<a href=\"\/\">Home<\/a>';\n\n  breadcrumb.forEach(function(item) {\n\n    html += `\n      <span class=\"m-breadcrumb--separator\" style=\"padding:0 10px;\">\n        \/\n      <\/span>\n      <a href=\"${item.url}\">\n        ${item.title}\n      <\/a>\n    `;\n  });\n\n  document.getElementById('dynamic-breadcrumb').innerHTML = html;\n\n});\n<\/script>","custom_class":""}}},"order":["annoucement","header","custom_liquid_7QGWxe"]}