{% comment %}
  Section: Visit Us Today
  A horizontally-scrolling "Store Locations" showcase with heading block,
  snap scrolling, custom progress indicator, keyboard nav, and drag-to-scroll.
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign inset_d = section.settings.left_inset_desktop
  assign inset_m = section.settings.left_inset_mobile
  assign card_w = section.settings.content_width
  assign card_gap = section.settings.card_gap
  assign pad_t = section.settings.section_padding_top
  assign pad_b = section.settings.section_padding_bottom
  assign mobile_card_vw = section.settings.mobile_card_width_vw
  assign peek_d = section.settings.peek_width_desktop

  assign show_info_icons = section.settings.show_info_icons
  assign icon_addr_type = section.settings.icon_address_type
  assign icon_hrs_type = section.settings.icon_hours_type
  assign icon_phn_type = section.settings.icon_phone_type
  assign icon_size = section.settings.icon_size
  assign icon_color_v = section.settings.icon_color
  assign icon_stroke = section.settings.icon_stroke_width
  assign icon_gap = section.settings.icon_gap
  assign icon_align_v = section.settings.icon_align
  assign icon_bg_style = section.settings.icon_background_style
  assign icon_bg_color = section.settings.icon_background_color
  assign icon_bg_size = section.settings.icon_background_size
  assign icon_bg_radius = section.settings.icon_background_radius
  assign icon_bg_border_color = section.settings.icon_background_border_color
  assign icon_bg_border_width = section.settings.icon_background_border_width

  if icon_align_v == 'center'
    assign icon_align_css = 'center'
  else
    assign icon_align_css = 'flex-start'
  endif

  if icon_bg_style == 'circle'
    assign icon_bg_radius_css = '999px'
  elsif icon_bg_style == 'square'
    assign icon_bg_radius_css = icon_bg_radius | append: 'px'
  else
    assign icon_bg_radius_css = '0'
  endif

  assign eyebrow_color = section.settings.eyebrow_color
  assign eyebrow_size = section.settings.eyebrow_size
  assign eyebrow_ls = section.settings.eyebrow_letter_spacing
  assign heading_color = section.settings.heading_color
  assign heading_size_d = section.settings.heading_size_desktop
  assign heading_size_m = section.settings.heading_size_mobile
  assign heading_ls = section.settings.heading_letter_spacing

  assign card_name_color = section.settings.card_name_color
  assign card_name_size = section.settings.card_name_size
  assign card_text_color = section.settings.card_text_color
  assign card_text_size = section.settings.card_text_size
  assign card_bg = section.settings.card_bg_color
  assign section_bg = section.settings.section_bg_color

  assign progress_track = section.settings.progress_track_color
  assign progress_fill = section.settings.progress_fill_color
  assign progress_h = section.settings.progress_height
  assign progress_mt = section.settings.progress_margin_top

  assign aspect = section.settings.image_aspect_ratio
  assign radius = section.settings.image_border_radius

  assign scroll_behavior = section.settings.scroll_behavior

  assign heading_tag = section.settings.heading_tag
  assign heading_align = section.settings.heading_alignment

  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
-%}

