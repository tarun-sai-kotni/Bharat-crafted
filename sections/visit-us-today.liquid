{%- liquid
  case icon_addr_type
    when 'pin'
      assign icon_addr_svg = svg_pin
    when 'location'
      assign icon_addr_svg = svg_location
    when 'building'
      assign icon_addr_svg = svg_building
    when 'map'
      assign icon_addr_svg = svg_map
    else
      assign icon_addr_svg = ''
  endcase

  case icon_hrs_type
    when 'clock'
      assign icon_hrs_svg = svg_clock
    when 'watch'
      assign icon_hrs_svg = svg_watch
    when 'calendar'
      assign icon_hrs_svg = svg_calendar
    when 'hourglass'
      assign icon_hrs_svg = svg_hourglass
    else
      assign icon_hrs_svg = ''
  endcase

  case icon_phn_type
    when 'phone'
      assign icon_phn_svg = svg_phone
    when 'mobile'
      assign icon_phn_svg = svg_mobile
    when 'whatsapp'
      assign icon_phn_svg = svg_whatsapp
    when 'message'
      assign icon_phn_svg = svg_message
    else
      assign icon_phn_svg = ''
  endcase
-%}

{%- style -%}
  #shopify-section-{{ section_id }} {
    --vut-inset-d: {{ inset_d }}px;
    --vut-inset-m: {{ inset_m }}px;
    --vut-card-w: {{ card_w }}px;
    --vut-card-gap: {{ card_gap }}px;
    --vut-pad-t: {{ pad_t }}px;
    --vut-pad-b: {{ pad_b }}px;
    --vut-mobile-card-w: {{ mobile_card_vw }}vw;
    --vut-peek-d: {{ peek_d }}px;

    --vut-icon-size: {{ icon_size }}px;
    --vut-icon-color: {{ icon_color_v }};
    --vut-icon-stroke: {{ icon_stroke }};
    --vut-icon-gap: {{ icon_gap }}px;
    --vut-icon-align: {{ icon_align_css }};
    --vut-icon-bg: {{ icon_bg_color }};
    --vut-icon-bg-size: {{ icon_bg_size }}px;
    --vut-icon-bg-radius: {{ icon_bg_radius_css }};
    --vut-icon-bg-border-color: {{ icon_bg_border_color }};
    --vut-icon-bg-border-width: {{ icon_bg_border_width }}px;

    --vut-eyebrow-color: {{ eyebrow_color }};
    --vut-eyebrow-size: {{ eyebrow_size }}px;
    --vut-eyebrow-ls: {{ eyebrow_ls }}px;

    --vut-heading-color: {{ heading_color }};
    --vut-heading-size-d: {{ heading_size_d }}px;
    --vut-heading-size-m: {{ heading_size_m }}px;
    --vut-heading-ls: {{ heading_ls }}px;

    --vut-card-name-color: {{ card_name_color }};
    --vut-card-name-size: {{ card_name_size }}px;
    --vut-card-text-color: {{ card_text_color }};
    --vut-card-text-size: {{ card_text_size }}px;
    --vut-card-bg: {{ card_bg }};
    --vut-section-bg: {{ section_bg }};

    --vut-progress-track: {{ progress_track }};
    --vut-progress-fill: {{ progress_fill }};
    --vut-progress-h: {{ progress_h }}px;
    --vut-progress-mt: {{ progress_mt }}px;

    --vut-radius: {{ radius }}px;

    background: var(--vut-section-bg);
  }

  #shopify-section-{{ section_id }} .vut {
    width: 100%;
    padding-top: var(--vut-pad-t);
    padding-bottom: var(--vut-pad-b);
    font-weight: var(--vut-body-weight);
    font-style: var(--vut-body-style);
    box-sizing: border-box;
  }

  #shopify-section-{{ section_id }} .vut *,
  #shopify-section-{{ section_id }} .vut *::before,
  #shopify-section-{{ section_id }} .vut *::after {
    box-sizing: border-box;
  }

  #shopify-section-{{ section_id }} .vut__header {
    padding-left: var(--vut-inset-d);
    padding-right: var(--vut-inset-d);
    margin-bottom: 1px;
    text-align: {{ heading_align }};
  }

  #shopify-section-{{ section_id }} .vut__eyebrow {
    display: block;
    color: var(--vut-eyebrow-color);
    font-size: var(--vut-eyebrow-size);
    letter-spacing: var(--vut-eyebrow-ls);
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section_id }} .vut__heading {
    display: block;
    color: var(--vut-heading-color);
    font-size: var(--vut-heading-size-d);
    letter-spacing: var(--vut-heading-ls);
    line-height: 1.05;
    margin: 0;
    font-weight: var(--vut-heading-weight);
    font-style: var(--vut-heading-style);
  }

  #shopify-section-{{ section_id }} .vut__scroller-wrap {
    position: relative;
    width: 100%;
  }

  #shopify-section-{{ section_id }} .vut__scroller {
    list-style: none;
    margin: 0;
    padding: 0 var(--vut-inset-d) 0 var(--vut-inset-d);
    display: flex;
    gap: var(--vut-card-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: {{ scroll_behavior }};
    scroll-padding-left: var(--vut-inset-d);
    {% if section.settings.enable_scroll_snap %}
    scroll-snap-type: x mandatory;
    {% endif %}
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
  }
  #shopify-section-{{ section_id }} .vut__scroller{
    display: unset !important;
  }

  #shopify-section-{{ section_id }} .vut__scroller::-webkit-scrollbar {
    display: none;
    height: 0;
    width: 0;
  }

  #shopify-section-{{ section_id }} .vut__card {
    flex: 0 0 min(var(--vut-card-w), calc(100vw - var(--vut-inset-d) - var(--vut-peek-d)));
    max-width: min(var(--vut-card-w), calc(100vw - var(--vut-inset-d) - var(--vut-peek-d)));
    {% if section.settings.enable_scroll_snap %}
    scroll-snap-align: start;
    scroll-snap-stop: always;
    {% endif %}
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    background: var(--vut-card-bg);
    border-radius: var(--vut-radius);
    overflow: hidden;
  }

  #shopify-section-{{ section_id }} .vut__card:focus-visible {
    outline: 2px solid var(--vut-progress-fill);
    outline-offset: 4px;
  }

  /* -------- Card style variants -------- */
  /* 1. Classic — image left, details right (default, inherits base grid) */

  /* 2. Reverse — details left, image right */
  #shopify-section-{{ section_id }} .vut__card--reverse .vut__media {
    grid-column: 2;
    grid-row: 1;
  }
  #shopify-section-{{ section_id }} .vut__card--reverse .vut__content {
    grid-column: 1;
    grid-row: 1;
  }

  /* 3. Stacked — image on top, details below */
  #shopify-section-{{ section_id }} .vut__card--stacked {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
  }
  #shopify-section-{{ section_id }} .vut__card--stacked .vut__media {
    aspect-ratio: 16 / 9;
  }
  #shopify-section-{{ section_id }} .vut__card--stacked .vut__content {
    padding: 40px 48px;
  }

  /* 4. Overlay — full image, content over gradient */
  #shopify-section-{{ section_id }} .vut__card--overlay {
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    position: relative;
    aspect-ratio: 4 / 5;
  }
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__media {
    grid-column: 1;
    grid-row: 1;
    aspect-ratio: auto;
    height: 100%;
  }
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__content {
    grid-column: 1;
    grid-row: 1;
    justify-content: flex-end;
    padding: 48px;
  }
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__content::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.25) 45%, rgba(0, 0, 0, 0) 70%);
    pointer-events: none;
  }
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__name,
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__info,
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__map-link,
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__label {
    color: #ffffff;
  }
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__phone {
    color: #ffffff;
  }

  /* 5. Framed — bordered card, image + details stacked with padding */
  #shopify-section-{{ section_id }} .vut__card--framed {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
    padding: 16px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: calc(var(--vut-radius) + 8px);
  }
  #shopify-section-{{ section_id }} .vut__card--framed .vut__media {
    aspect-ratio: 4 / 3;
  }
  #shopify-section-{{ section_id }} .vut__card--framed .vut__content {
    padding: 32px 24px 16px;
  }

  /* 6. Luxury — dark charcoal card with gold accents */
  #shopify-section-{{ section_id }} .vut__card--luxury {
    background: #111111;
    color: #f8f3e9;
    border-radius: calc(var(--vut-radius) + 10px);
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25), 0 20px 60px rgba(0, 0, 0, 0.25);
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__media {
    filter: brightness(0.92) contrast(1.02);
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__content {
    padding: 48px 56px;
    gap: 24px;
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__name {
    color: #f8f3e9;
    position: relative;
    padding-top: 28px;
    letter-spacing: -0.025em;
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__name::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 56px;
    height: 1.5px;
    background: var(--vut-eyebrow-color);
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #shopify-section-{{ section_id }} .vut__card--luxury:hover .vut__name::before,
  #shopify-section-{{ section_id }} .vut__card--luxury:focus-within .vut__name::before {
    width: 88px;
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__info,
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__address,
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__hours,
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__phone-wrap {
    color: rgba(248, 243, 233, 0.82);
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__phone {
    color: rgba(248, 243, 233, 0.92);
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__label {
    color: var(--vut-eyebrow-color);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 11px;
    opacity: 0.9;
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__map-link {
    color: var(--vut-eyebrow-color) !important;
  }
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__link-divider {
    background: rgba(248, 243, 233, 0.18);
    opacity: 1;
  }

  /* 7. Editorial — oversized magazine-style split with big name */
  #shopify-section-{{ section_id }} .vut__card--editorial {
    grid-template-columns: 1.3fr 1fr;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__media {
    aspect-ratio: 5 / 6;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__content {
    padding: 56px 64px;
    justify-content: flex-start;
    gap: 28px;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__name {
    font-size: calc(var(--vut-card-name-size) * 1.25);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: 8px;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__name::after {
    content: '';
    display: block;
    width: 64px;
    height: 2px;
    background: var(--vut-eyebrow-color);
    margin-top: 24px;
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #shopify-section-{{ section_id }} .vut__card--editorial:hover .vut__name::after,
  #shopify-section-{{ section_id }} .vut__card--editorial:focus-within .vut__name::after {
    width: 104px;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__info {
    max-width: 360px;
  }
  #shopify-section-{{ section_id }} .vut__card--editorial .vut__label {
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 10.5px;
    opacity: 0.55;
  }

  /* 8. Portrait — vertical centered gallery card */
  #shopify-section-{{ section_id }} .vut__card--portrait {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
    background: var(--vut-card-bg);
    border-radius: calc(var(--vut-radius) + 14px);
    overflow: hidden;
    box-shadow:
      0 1px 3px rgba(17, 17, 17, 0.05),
      0 10px 30px rgba(17, 17, 17, 0.05);
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__media {
    aspect-ratio: 3 / 4;
    border-radius: 0;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__content {
    padding: 36px 40px 44px;
    align-items: center;
    text-align: center;
    gap: 18px;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__name {
    font-size: calc(var(--vut-card-name-size) * 0.78);
    letter-spacing: -0.02em;
    position: relative;
    padding-bottom: 22px;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__name::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 36px;
    height: 1px;
    background: var(--vut-eyebrow-color);
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #shopify-section-{{ section_id }} .vut__card--portrait:hover .vut__name::after,
  #shopify-section-{{ section_id }} .vut__card--portrait:focus-within .vut__name::after {
    width: 64px;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__info {
    align-items: center;
    text-align: center;
    max-width: 320px;
    margin: 0 auto;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__label {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 11px;
    opacity: 0.6;
  }
  #shopify-section-{{ section_id }} .vut__card--portrait .vut__map-link {
    align-self: center;
  }

  /* Mobile: collapse all styles to stacked single-column feel, but keep overlay full-bleed */
  @media (max-width: 767px) {
    #shopify-section-{{ section_id }} .vut__card--reverse .vut__media,
    #shopify-section-{{ section_id }} .vut__card--reverse .vut__content {
      grid-column: 1;
    }
    #shopify-section-{{ section_id }} .vut__card--reverse .vut__media {
      grid-row: 1;
    }
    #shopify-section-{{ section_id }} .vut__card--reverse .vut__content {
      grid-row: 2;
    }
    #shopify-section-{{ section_id }} .vut__card--overlay {
      aspect-ratio: 3 / 4;
    }
    /* New premium styles — scale padding + typography down on mobile */
    #shopify-section-{{ section_id }} .vut__card--luxury .vut__content,
    #shopify-section-{{ section_id }} .vut__card--editorial .vut__content,
    #shopify-section-{{ section_id }} .vut__card--portrait .vut__content {
      padding: 28px 24px;
      gap: 16px;
    }
    #shopify-section-{{ section_id }} .vut__card--editorial .vut__name {
