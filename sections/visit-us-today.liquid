    line-height: 0;
    /* Nudge icon slightly for top-align so it visually centers with first line */
    margin-top: 0;
  }
  #shopify-section-{{ section_id }} .vut__icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: var(--vut-icon-stroke);
    stroke-linecap: round;
    stroke-linejoin: round;
    overflow: visible;
  }
  /* Tiny nudge for top-aligned icons so they sit visually on the text x-height */
  #shopify-section-{{ section_id }} .vut__info-row.vut__info-row--top .vut__icon:not(.vut__icon--boxed) {
    margin-top: 0.12em;
  }

  /* Icon background (circle or rounded square) */
  #shopify-section-{{ section_id }} .vut__icon--boxed {
    width: var(--vut-icon-bg-size);
    height: var(--vut-icon-bg-size);
    background: var(--vut-icon-bg);
    border-radius: var(--vut-icon-bg-radius);
    border: var(--vut-icon-bg-border-width) solid var(--vut-icon-bg-border-color);
  }
  #shopify-section-{{ section_id }} .vut__icon--boxed svg {
    width: var(--vut-icon-size);
    height: var(--vut-icon-size);
  }

  /* Overlay style — icons inherit the white overlay text color */
  #shopify-section-{{ section_id }} .vut__card--overlay .vut__icon {
    color: #ffffff;
  }
  /* Luxury style — icons in gold */
  #shopify-section-{{ section_id }} .vut__card--luxury .vut__icon {
    color: var(--vut-eyebrow-color);
  }
  /* -------- /Info icons -------- */

  #shopify-section-{{ section_id }} .vut__phone {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section_id }} .vut__phone:hover {
    text-decoration: underline;
  }

  #shopify-section-{{ section_id }} .vut__map-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--vut-card-text-size);
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s ease;
    align-self: flex-start;
  }

  #shopify-section-{{ section_id }} .vut__map-link--underline {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #shopify-section-{{ section_id }} .vut__map-link:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section_id }} .vut__map-link svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section_id }} .vut__link-divider {
    width: 100%;
    height: 1px;
    background: currentColor;
    opacity: 0.15;
    margin: 0;
    border: 0;
  }

  #shopify-section-{{ section_id }} .vut__progress {
    position: relative;
    height: var(--vut-progress-h);
    background: var(--vut-progress-track);
    margin: var(--vut-progress-mt) var(--vut-inset-d);
    cursor: pointer;
    touch-action: none;
    border-radius: calc(var(--vut-progress-h) / 2);
  }

  #shopify-section-{{ section_id }} .vut__progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 20%;
    background: var(--vut-progress-fill);
    transform-origin: left center;
    will-change: left, width;
    border-radius: calc(var(--vut-progress-h) / 2);
  }

  #shopify-section-{{ section_id }} .vut__empty {
    padding: 80px var(--vut-inset-d);
    text-align: center;
    color: var(--vut-heading-color);
    opacity: 0.6;
  }

  @media (max-width: 1024px) {
    #shopify-section-{{ section_id }} .vut__content {
      padding: 32px 48px;
      gap: 24px;
    }
    #shopify-section-{{ section_id }} .vut__name {
      font-size: calc(var(--vut-card-name-size) * 0.75);
    }
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section_id }} .vut__header {
      padding-left: var(--vut-inset-m);
      padding-right: var(--vut-inset-m);
      margin-bottom: 32px;
    }

    #shopify-section-{{ section_id }} .vut__heading {
      font-size: var(--vut-heading-size-m);
    }

    #shopify-section-{{ section_id }} .vut__scroller {
      padding: 0 var(--vut-inset-m);
      gap: calc(var(--vut-card-gap) * 0.5);
    }

    #shopify-section-{{ section_id }} .vut__card {
      flex: 0 0 var(--vut-mobile-card-w);
      max-width: var(--vut-mobile-card-w);
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }

    #shopify-section-{{ section_id }} .vut__content {
      padding: 24px 20px;
      gap: 16px;
    }

    #shopify-section-{{ section_id }} .vut__name {
      font-size: calc(var(--vut-card-name-size) * 0.6);
    }

    #shopify-section-{{ section_id }} .vut__progress {
      margin: calc(var(--vut-progress-mt) * 0.75) var(--vut-inset-m);
    }

    #shopify-section-{{ section_id }} .vut__empty {
      padding: 60px var(--vut-inset-m);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section_id }} .vut__scroller {
      scroll-behavior: auto;
    }
    #shopify-section-{{ section_id }} .vut__progress-fill {
      transition: none !important;
    }
  }
{%- endstyle -%}

<section
  class="vut{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
  aria-labelledby="vut-heading-{{ section_id }}"
  data-vut-root
  data-section-id="{{ section_id }}"
  data-enable-keyboard="{{ section.settings.enable_keyboard_nav }}"
  data-enable-drag="{{ section.settings.enable_drag_progress }}"
  data-show-progress="{{ section.settings.show_progress_bar }}"
  data-enable-loop="{{ section.settings.enable_infinite_loop }}"
  data-enable-mouse-drag="{{ section.settings.enable_mouse_drag }}"
  data-enable-auto="{{ section.settings.enable_auto_scroll }}"
  data-auto-interval="{{ section.settings.auto_scroll_interval | times: 1000 }}"
  data-pause-on-hover="{{ section.settings.auto_scroll_pause_on_hover }}"
>
  <div class="vut__header">
    {%- if section.settings.eyebrow_text != blank -%}
      <span class="vut__eyebrow">{{ section.settings.eyebrow_text }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <{{ heading_tag }} id="vut-heading-{{ section_id }}" class="vut__heading">
        {{ section.settings.heading }}
      </{{ heading_tag }}>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="vut__scroller-wrap">
      <ol
        class="vut__scroller"
        id="vut-scroller-{{ section_id }}"
        data-vut-scroller
        tabindex="0"
        aria-label="{{ section.settings.heading | default: 'Store locations' }}"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign link_color = block.settings.link_color
            assign link_underline = block.settings.link_underline
            assign show_divider = block.settings.show_divider_above_link

            assign bg_type = block.settings.content_bg_type | default: 'none'
            assign bg_color = block.settings.content_bg_color
            assign bg_image = block.settings.content_bg_image
            assign bg_opacity_raw = block.settings.content_bg_overlay_opacity | default: 0
            assign bg_opacity = bg_opacity_raw | times: 1.0 | divided_by: 100.0

            assign content_style = ''
            if bg_type == 'color' and bg_color != blank
              assign content_style = 'background-color: ' | append: bg_color | append: ';'
            elsif bg_type == 'image' and bg_image != blank
              assign bg_img_url = bg_image | image_url: width: 1600
              assign content_style = "background-image: url('" | append: bg_img_url | append: "');"
            elsif bg_type == 'both' and bg_image != blank
              assign bg_img_url = bg_image | image_url: width: 1600
              assign content_style = "background-image: url('" | append: bg_img_url | append: "');"
            endif

            assign overlay_rgba = ''
            if bg_type == 'both' and bg_image != blank and bg_color != blank and bg_opacity_raw > 0
              assign overlay_rgba = bg_color | color_modify: 'alpha', bg_opacity
            endif
          -%}
          {%- assign card_style = block.settings.card_style | default: 'classic' -%}
          {%- assign block_class = block.settings.custom_class -%}
          {%- assign card_idx = forloop.index -%}
          {%- if card_idx < 10 -%}
            {%- assign card_num_str = '0' | append: card_idx -%}
          {%- else -%}
            {%- capture card_num_str -%}{{ card_idx }}{%- endcapture -%}
          {%- endif -%}
          <li
            class="vut__card vut__card--{{ card_style }}{% if block_class != blank %} {{ block_class | escape }}{% endif %}"
            data-card-style="{{ card_style }}"
            data-card-index="{{ card_num_str }}"
            tabindex="0"
            data-vut-card
            {{ block.shopify_attributes }}
          >
            <div class="vut__media">
              {%- if block.settings.image != blank -%}
                {%- assign alt = block.settings.image_alt | default: block.settings.store_name -%}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1600 }} 1600w"
                  sizes="(max-width: 767px) 85vw, 636px"
                  alt="{{ alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                />
              {%- else -%}
                <div class="vut__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'vut__placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            <div class="vut__content"{% if content_style != blank %} style="{{ content_style }}"{% endif %} data-bg-type="{{ bg_type }}">
              {%- if overlay_rgba != blank -%}
                <span class="vut__content-overlay" style="background-color: {{ overlay_rgba }};" aria-hidden="true"></span>
              {%- endif -%}
              {%- if block.settings.store_name != blank -%}
                <h3 class="vut__name">{{ block.settings.store_name }}</h3>
              {%- endif -%}

              {%- assign icon_boxed_class = '' -%}
              {%- if icon_bg_style != 'none' -%}{%- assign icon_boxed_class = ' vut__icon--boxed' -%}{%- endif -%}
              {%- assign row_align_class = '' -%}
              {%- if icon_align_v == 'top' -%}{%- assign row_align_class = ' vut__info-row--top' -%}{%- endif -%}

              <div class="vut__info">
                {%- if block.settings.address != blank -%}
                  <address class="vut__address vut__info-row{{ row_align_class }}">
                    {%- if show_info_icons and icon_addr_svg != blank -%}
                      <span class="vut__icon{{ icon_boxed_class }}" aria-hidden="true">{{ icon_addr_svg }}</span>
                    {%- endif -%}
                    <span class="vut__info-text">{{ block.settings.address }}</span>
                  </address>
                {%- endif -%}

                {%- if block.settings.hours != blank -%}
                  <p class="vut__hours vut__info-row{{ row_align_class }}">
                    {%- if show_info_icons and icon_hrs_svg != blank -%}
                      <span class="vut__icon{{ icon_boxed_class }}" aria-hidden="true">{{ icon_hrs_svg }}</span>
                    {%- endif -%}
                    <span class="vut__info-text">
                      <span class="vut__label">Hours</span>
                      {{ block.settings.hours }}
                    </span>
                  </p>
                {%- endif -%}

                {%- if block.settings.phone != blank -%}
                  <p class="vut__phone-wrap vut__info-row{{ row_align_class }}">
                    {%- if show_info_icons and icon_phn_svg != blank -%}
                      <span class="vut__icon{{ icon_boxed_class }}" aria-hidden="true">{{ icon_phn_svg }}</span>
                    {%- endif -%}
                    <span class="vut__info-text">
                      <span class="vut__label">Phone</span>
                      {%- if block.settings.phone_link != blank -%}
                        <a class="vut__phone" href="{{ block.settings.phone_link }}">{{ block.settings.phone }}</a>
                      {%- else -%}
                        {{ block.settings.phone }}
                      {%- endif -%}
                    </span>
                  </p>
                {%- endif -%}
              </div>

              {%- if show_divider -%}
                <hr class="vut__link-divider" style="color: {{ link_color }};">
              {%- endif -%}

              {%- if block.settings.map_link != blank -%}
                <a
                  class="vut__map-link{% if link_underline %} vut__map-link--underline{% endif %}"
                  href="{{ block.settings.map_link }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="color: {{ link_color }};"
                >
                  {{ block.settings.map_link_label | default: 'View on Google Maps' }}
                  <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M6 3h7v7M13 3L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>

      {%- if section.settings.show_progress_bar -%}
        <div
          class="vut__progress"
          data-vut-progress
          role="scrollbar"
          aria-controls="vut-scroller-{{ section_id }}"
          aria-orientation="horizontal"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="0"
          tabindex="0"
        >
          <div class="vut__progress-fill" data-vut-progress-fill></div>
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    {%- if request.design_mode -%}
      <div class="vut__empty">
        <p><strong>Add your first store location</strong></p>
        <p>Use the theme editor to add store blocks with images, addresses, hours, and directions.</p>
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

<script>
  (function () {
    'use strict';

    function initVUT(root) {
      if (!root || root.__vutInitialised) return;
      root.__vutInitialised = true;

      var scroller = root.querySelector('[data-vut-scroller]');
      if (!scroller) return;

      var progress = root.querySelector('[data-vut-progress]');
      var fill = root.querySelector('[data-vut-progress-fill]');

      var enableKeyboard = root.getAttribute('data-enable-keyboard') === 'true';
      var enableDrag = root.getAttribute('data-enable-drag') === 'true';
      var showProgress = root.getAttribute('data-show-progress') === 'true';
      var enableLoop = root.getAttribute('data-enable-loop') === 'true';
      var enableAuto = root.getAttribute('data-enable-auto') === 'true';
      var enableMouseDrag = root.getAttribute('data-enable-mouse-drag') === 'true';
      var autoInterval = parseInt(root.getAttribute('data-auto-interval'), 10) || 4000;
      var pauseOnHover = root.getAttribute('data-pause-on-hover') !== 'false';

      // Hoisted API so mouse-drag (defined later) can call into auto-scroll
      var autoAPI = { pause: function () {}, resume: function () {} };
      // Shared flag so loop wrap-detection can suspend itself while the user is dragging
      var isUserDragging = false;

      var reduceMotion =
        window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Infinite loop setup (clones once before + once after real set) ----
      var originalCards = Array.prototype.slice.call(
        scroller.querySelectorAll('[data-vut-card]:not([data-vut-clone])')
      );
      var realCount = originalCards.length;
      var isWrapping = false;

      if (enableLoop && realCount > 1) {
        var fragPre = document.createDocumentFragment();
        var fragPost = document.createDocumentFragment();
        function markClone(clone, kind) {
          clone.setAttribute('aria-hidden', 'true');
          clone.setAttribute('data-vut-clone', kind);
          clone.setAttribute('tabindex', '-1');
          clone.removeAttribute('id');
          // Prefer inert (removes from tab order + AT tree); fall back to per-child tabindex
          if ('inert' in HTMLElement.prototype) {
            clone.inert = true;
          } else {
            clone.querySelectorAll('a, button, input, select, textarea, [tabindex]').forEach(function (el) {
              el.setAttribute('tabindex', '-1');
            });
          }
        }
        originalCards.forEach(function (card) {
          var pre = card.cloneNode(true);
          markClone(pre, 'pre');
          fragPre.appendChild(pre);

          var post = card.cloneNode(true);
          markClone(post, 'post');
          fragPost.appendChild(post);
        });
        scroller.appendChild(fragPost);
        scroller.insertBefore(fragPre, scroller.firstChild);
      }

      // Cards list AFTER any cloning — used for keyboard/focus
      var cards = scroller.querySelectorAll('[data-vut-card]');

      function getCycleMetrics() {
        if (!enableLoop || realCount < 2) return null;
        var firstReal = scroller.querySelector('[data-vut-card]:not([data-vut-clone])');
        if (!firstReal) return null;
        var cardW = firstReal.getBoundingClientRect().width;
        var style = window.getComputedStyle(scroller);
        var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
        var cycle = realCount * (cardW + gap);
        return { cardW: cardW, gap: gap, cycle: cycle, firstReal: firstReal };
      }

      // Position scroller at the first real card after clones are laid out.
      if (enableLoop && realCount > 1) {
        requestAnimationFrame(function () {
          var m = getCycleMetrics();
          if (!m) return;
          var insetPx = parseFloat(window.getComputedStyle(scroller).scrollPaddingLeft) || 0;
          isWrapping = true;
          scroller.scrollLeft = m.firstReal.offsetLeft - insetPx;
          requestAnimationFrame(function () { isWrapping = false; });
        });
      }

      var rafId = null;

      function updateProgress() {
        rafId = null;
        if (!progress || !fill || !showProgress) return;

        // Loop-aware progress: show position within the real set
        if (enableLoop && realCount > 1) {
          var m = getCycleMetrics();
          if (m && m.cycle > 0) {
            var cw = scroller.clientWidth;
            var rel = (((scroller.scrollLeft - m.cycle) % m.cycle) + m.cycle) % m.cycle;
            var viewPct = Math.min(100, (cw / m.cycle) * 100);
            var leftPct = Math.min(100 - viewPct, (rel / m.cycle) * 100);
            fill.style.left = leftPct + '%';
            fill.style.width = viewPct + '%';
            progress.setAttribute('aria-valuenow', String(Math.round((rel / m.cycle) * 100)));
            return;
          }
        }

        var sw = scroller.scrollWidth;
        var cwNat = scroller.clientWidth;
        var sl = scroller.scrollLeft;

        if (sw <= cwNat) {
          fill.style.left = '0%';
          fill.style.width = '100%';
          progress.setAttribute('aria-valuenow', '0');
          return;
        }

        var widthPct = (cwNat / sw) * 100;
        var leftPct2 = (sl / sw) * 100;
        fill.style.left = leftPct2 + '%';
        fill.style.width = widthPct + '%';

        var maxScroll = sw - cwNat;
        var pct = maxScroll > 0 ? Math.round((sl / maxScroll) * 100) : 0;
        progress.setAttribute('aria-valuenow', String(pct));
      }

      function scheduleUpdate() {
        if (rafId !== null) return;
        rafId = requestAnimationFrame(updateProgress);
      }

      // Wrap detection: when scroll idles, jump silently if we're in a clone zone.
      var wrapTimer = null;
      function maybeWrap() {
        if (!enableLoop || realCount < 2 || isWrapping || isUserDragging) return;
        var m = getCycleMetrics();
        if (!m || m.cycle <= 0) return;
        var lower = m.cycle;
        var upper = 2 * m.cycle;
        var sl = scroller.scrollLeft;
        var prevBehavior = scroller.style.scrollBehavior;
        if (sl >= upper - 1) {
          isWrapping = true;
          scroller.style.scrollBehavior = 'auto';
          scroller.scrollLeft = sl - m.cycle;
          scroller.style.scrollBehavior = prevBehavior;
          requestAnimationFrame(function () { isWrapping = false; });
        } else if (sl < lower) {
          isWrapping = true;
          scroller.style.scrollBehavior = 'auto';
          scroller.scrollLeft = sl + m.cycle;
          scroller.style.scrollBehavior = prevBehavior;
          requestAnimationFrame(function () { isWrapping = false; });
        }
      }

      function scheduleWrap() {
        if (!enableLoop) return;
        clearTimeout(wrapTimer);
        wrapTimer = setTimeout(maybeWrap, 90);
      }

      scroller.addEventListener('scroll', function () {
        scheduleUpdate();
        scheduleWrap();
      }, { passive: true });
      window.addEventListener('resize', scheduleUpdate);

      // Initial paint
      updateProgress();

      // Keyboard navigation
      if (enableKeyboard) {
        function getStep() {
          var first = cards[0];
          if (!first) return scroller.clientWidth;
          var style = window.getComputedStyle(scroller);
          var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
          return first.getBoundingClientRect().width + gap;
        }

        scroller.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
            e.preventDefault();
            var step = getStep();
            scroller.scrollBy({
              left: e.key === 'ArrowRight' ? step : -step,
              behavior: reduceMotion ? 'auto' : 'smooth',
            });
          } else if (e.key === 'Home') {
            e.preventDefault();
            scroller.scrollTo({ left: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          } else if (e.key === 'End') {
            e.preventDefault();
            scroller.scrollTo({
              left: scroller.scrollWidth,
              behavior: reduceMotion ? 'auto' : 'smooth',
            });
          }
        });

        // When a card gets focus, keep it visible
        cards.forEach(function (card) {
          card.addEventListener('focus', function () {
            var cardRect = card.getBoundingClientRect();
            var wrapRect = scroller.getBoundingClientRect();
            if (cardRect.left < wrapRect.left || cardRect.right > wrapRect.right) {
              card.scrollIntoView({
                behavior: reduceMotion ? 'auto' : 'smooth',
                inline: 'start',
                block: 'nearest',
              });
            }
          });
        });
      }

      // Drag / click on progress bar
      if (enableDrag && progress && showProgress) {
        var dragging = false;

        function pointerToScroll(clientX) {
          var rect = progress.getBoundingClientRect();
          if (rect.width <= 0) return;
          var ratio = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
          var cw = scroller.clientWidth;

          // Loop-aware: map ratio to position within the real set
          if (enableLoop && realCount > 1) {
            var m = getCycleMetrics();
            if (m && m.cycle > 0) {
              var within = ratio * m.cycle - cw / 2;
              var target = m.cycle + Math.max(0, Math.min(m.cycle - cw, within));
              scroller.scrollTo({
                left: target,
                behavior: dragging || reduceMotion ? 'auto' : 'smooth',
              });
              return;
            }
          }

          var sw = scroller.scrollWidth;
          var maxScroll = Math.max(0, sw - cw);
          var target2 = ratio * sw - cw / 2;
          target2 = Math.max(0, Math.min(maxScroll, target2));
          scroller.scrollTo({
            left: target2,
            behavior: dragging || reduceMotion ? 'auto' : 'smooth',
          });
        }

        progress.addEventListener('pointerdown', function (e) {
          dragging = true;
          try { progress.setPointerCapture(e.pointerId); } catch (err) {}
          pointerToScroll(e.clientX);
        });
        progress.addEventListener('pointermove', function (e) {
          if (!dragging) return;
          pointerToScroll(e.clientX);
        });
        function endDrag(e) {
          if (!dragging) return;
          dragging = false;
          try { progress.releasePointerCapture(e.pointerId); } catch (err) {}
        }
        progress.addEventListener('pointerup', endDrag);
        progress.addEventListener('pointercancel', endDrag);

        // Keyboard support on scrollbar element
        progress.addEventListener('keydown', function (e) {
          var sw = scroller.scrollWidth;
          var cw = scroller.clientWidth;
          var maxScroll = Math.max(0, sw - cw);
          if (!maxScroll) return;
          var step = cw * 0.25;
          var left = scroller.scrollLeft;
          if (e.key === 'ArrowRight') {
            e.preventDefault();
            scroller.scrollTo({ left: Math.min(maxScroll, left + step), behavior: reduceMotion ? 'auto' : 'smooth' });
          } else if (e.key === 'ArrowLeft') {
            e.preventDefault();
            scroller.scrollTo({ left: Math.max(0, left - step), behavior: reduceMotion ? 'auto' : 'smooth' });
          } else if (e.key === 'Home') {
            e.preventDefault();
            scroller.scrollTo({ left: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
          } else if (e.key === 'End') {
            e.preventDefault();
            scroller.scrollTo({ left: maxScroll, behavior: reduceMotion ? 'auto' : 'smooth' });
          }
        });
      }

      // ---- Auto-scroll ----
      if (enableAuto && !reduceMotion && cards.length > 1) {
        var autoTimer = null;
        var autoPaused = false;

        function autoStep() {
          var firstCard = cards[0];
          if (!firstCard) return;
          var style = window.getComputedStyle(scroller);
          var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
          var step = firstCard.getBoundingClientRect().width + gap;
          var sw = scroller.scrollWidth;
          var cw = scroller.clientWidth;
          var sl = scroller.scrollLeft;
          var nextLeft = sl + step;

          if (!enableLoop && nextLeft >= sw - cw - 1) {
            // Snap back to start at the end (non-loop fallback cycle)
            scroller.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            scroller.scrollTo({ left: nextLeft, behavior: 'smooth' });
          }
        }

        function startAuto() {
          if (autoTimer || autoPaused) return;
          autoTimer = setInterval(function () {
            if (document.hidden) return;
            autoStep();
          }, autoInterval);
        }
        function stopAuto() {
          if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
        }
        function pauseAuto() { autoPaused = true; stopAuto(); }
        function resumeAuto() { autoPaused = false; startAuto(); }
        autoAPI.pause = pauseAuto;
        autoAPI.resume = resumeAuto;

        if (pauseOnHover) {
          root.addEventListener('pointerenter', pauseAuto);
          root.addEventListener('pointerleave', resumeAuto);
          root.addEventListener('focusin', pauseAuto);
          root.addEventListener('focusout', resumeAuto);
        }
        // Always pause during active touch drag
        scroller.addEventListener('touchstart', pauseAuto, { passive: true });
        scroller.addEventListener('touchend', function () {
          setTimeout(resumeAuto, 400);
        }, { passive: true });

        document.addEventListener('visibilitychange', function () {
          if (document.hidden) stopAuto(); else if (!autoPaused) startAuto();
        });

        // Pause while section is off-screen to save CPU
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (!autoPaused) startAuto();
              } else {
                stopAuto();
              }
            });
          }, { threshold: 0.1 });
          io.observe(root);
        } else {
          startAuto();
        }
      }

      // ---- Mouse drag-to-scroll (desktop only) ----
      if (enableMouseDrag) {
        var md = { active: false, pointerId: -1, startX: 0, startScroll: 0, moved: false };
        var DRAG_THRESHOLD = 4;

        // Disable native image drag so a USB mouse can't start a drag-n-drop
        scroller.querySelectorAll('img').forEach(function (img) {
          img.setAttribute('draggable', 'false');
        });

        scroller.addEventListener('pointerdown', function (e) {
          if (e.pointerType !== 'mouse' || e.button !== 0) return;
          if (e.target && e.target.closest && e.target.closest('[data-vut-progress]')) return;
          md.active = true;
          md.pointerId = e.pointerId;
          md.startX = e.clientX;
          md.startScroll = scroller.scrollLeft;
          md.moved = false;
          // Capture immediately so a fast-moving mouse doesn't escape the scroller
          // box before we've engaged — otherwise pointermove events stop arriving.
          try { scroller.setPointerCapture(e.pointerId); } catch (err) {}
        });

        // Handler shared by scroller-capture path AND the document fallback path
        function handleMove(e) {
          if (!md.active || e.pointerId !== md.pointerId) return;
          if (e.pointerType && e.pointerType !== 'mouse') return;
          var dx = e.clientX - md.startX;
          if (!md.moved) {
            if (Math.abs(dx) < DRAG_THRESHOLD) return;
            md.moved = true;
            isUserDragging = true;
            scroller.classList.add('vut--grabbing');
            autoAPI.pause();
          }
          if (e.cancelable) e.preventDefault();
          var prev = scroller.style.scrollBehavior;
          scroller.style.scrollBehavior = 'auto';
          scroller.scrollLeft = md.startScroll - dx;
          scroller.style.scrollBehavior = prev;
        }
        scroller.addEventListener('pointermove', handleMove);
        // Fallback: if pointer capture isn't honoured (rare), document still sees moves
        document.addEventListener('pointermove', handleMove);

        function endMouseDrag(e) {
          if (!md.active) return;
          if (e && e.pointerId !== undefined && e.pointerId !== md.pointerId) return;
          var wasMoved = md.moved;
          try { scroller.releasePointerCapture(md.pointerId); } catch (err) {}
          md.active = false;
          isUserDragging = false;
          if (wasMoved) {
            scroller.classList.remove('vut--grabbing');
            autoAPI.resume();
            // Swallow the synthetic click that follows a drag
            var blocker = function (ev) {
              ev.stopPropagation();
              ev.preventDefault();
            };
            scroller.addEventListener('click', blocker, true);
            setTimeout(function () {
              scroller.removeEventListener('click', blocker, true);
            }, 80);
          }
          md.pointerId = -1;
        }

        scroller.addEventListener('pointerup', endMouseDrag);
        scroller.addEventListener('pointercancel', endMouseDrag);
        scroller.addEventListener('lostpointercapture', endMouseDrag);
        document.addEventListener('pointerup', endMouseDrag);
        document.addEventListener('pointercancel', endMouseDrag);

        // Kill native drag + text-selection for the whole active drag (not just post-threshold)
        scroller.addEventListener('dragstart', function (e) {
          if (md.active) e.preventDefault();
        });
        scroller.addEventListener('selectstart', function (e) {
          if (md.active) e.preventDefault();
        });
      }
    }

    function initAll() {
      var roots = document.querySelectorAll('[data-vut-root]');
      roots.forEach(initVUT);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }

    // Shopify section rendering API hooks
    if (typeof document !== 'undefined') {
      document.addEventListener('shopify:section:load', function (e) {
        var root = e.target.querySelector('[data-vut-root]');
        if (root) initVUT(root);
      });
      document.addEventListener('shopify:section:reorder', function (e) {
        var root = e.target.querySelector('[data-vut-root]');
        if (root) initVUT(root);
      });
      document.addEventListener('shopify:block:select', function (e) {
        var card = e.target.closest('[data-vut-card]');
        if (card && card.scrollIntoView) {
          card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });
    }
  })();
</script>

