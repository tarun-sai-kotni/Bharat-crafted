    "custom_liquid_fB99Qi": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Features Strip</title>\n    <script src=\"https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js\"></script>\n\n    <style id=\"reset\">\n      * {\n        box-sizing: border-box;\n        margin: 0;\n        padding: 0;\n      }\n      :root {\n        --maroon: #7b011e;\n        --maroon-dark: #580015;\n        --maroon-deep: #3a000d;\n        --gold: #c9922a;\n        --gold-light: #e8bf6a;\n        --cream: #fdf8ee;\n        --font-sans: \"Segoe UI\", system-ui, -apple-system, sans-serif;\n      }\n      body {\n        background: var(--maroon-deep);\n        font-family: var(--font-sans);\n      }\n    </style>\n\n    <style id=\"features-strip\">\n      /* Outer band */\n      .features-strip {\n        width: 100%;\n        background: var(--maroon);\n        border-top: 1px solid rgba(201, 146, 42, 0.2);\n        overflow: hidden;\n      }\n\n      /* Track that holds the items */\n      .features-track {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        padding: 12px 88px;\n        width: 100%;\n      }\n\n      .feature-item {\n        display: flex;\n        align-items: center;\n        gap: 14px;\n        flex-shrink: 0;\n      }\n      .feature-icon-wrap {\n        width: 42px;\n        height: 42px;\n        border-radius: 50%;\n        border: 1px solid rgba(201, 146, 42, 0.3);\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        background: rgba(201, 146, 42, 0.07);\n        flex-shrink: 0;\n      }\n      .feature-text {\n        display: flex;\n        flex-direction: column;\n        gap: 2px;\n      }\n      .feature-title {\n        font-family: var(--font-sans);\n        font-size: 13px;\n        font-weight: 600;\n        color: var(--cream);\n        white-space: nowrap;\n      }\n      .feature-sub {\n        font-family: var(--font-sans);\n        font-size: 11px;\n        color: rgba(253, 248, 238, 0.45);\n        white-space: nowrap;\n      }\n      .feature-sep {\n        width: 1px;\n        height: 40px;\n        background: rgba(201, 146, 42, 0.18);\n        flex-shrink: 0;\n      }\n\n      /* Second copy is only needed for the mobile loop - hidden on desktop */\n      .features-loop {\n        display: none;\n      }\n\n      /* MOBILE: smooth slow auto-scroll */\n      @media (max-width: 768px) {\n        .features-track {\n          width: max-content;\n          justify-content: flex-start;\n          gap: 28px;\n          padding: 11px 0;\n          animation: feature-scroll 30s linear infinite;\n        }\n        .features-loop {\n          display: flex;\n        }\n      }\n\n      @keyframes feature-scroll {\n        from {\n          transform: translateX(0);\n        }\n        to {\n          transform: translateX(-50%);\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <!-- FEATURES STRIP (ICONS SECTION) -->\n    <div class=\"features-strip\">\n      <div class=\"features-track\">\n        <!-- SET 1 -->\n        <div class=\"feature-item\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:shield-check\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Authentic Designs</span>\n            <span class=\"feature-sub\">Handpicked ethnic collections</span>\n          </div>\n        </div>\n        <div class=\"feature-sep\"></div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:truck\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Free Shipping</span>\n            <span class=\"feature-sub\">Across India on all orders</span>\n          </div>\n        </div>\n        <div class=\"feature-sep\"></div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:refresh-cw\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Festive Specials</span>\n            <span class=\"feature-sub\">Perfect For Every Occasion</span>\n          </div>\n        </div>\n        <div class=\"feature-sep\"></div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:award\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Secure Payments</span>\n            <span class=\"feature-sub\">100% Safe Checkout</span>\n          </div>\n        </div>\n        <div class=\"feature-sep\"></div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:headphones\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Concierge Support</span>\n            <span class=\"feature-sub\">Personal styling guidance</span>\n          </div>\n        </div>\n\n        <!-- SET 2 - duplicate, only shows on mobile for a seamless loop -->\n        <div class=\"feature-sep features-loop\"></div>\n        <div class=\"feature-item features-loop\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:shield-check\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">100% Pure Silk</span>\n            <span class=\"feature-sub\">Certified authenticity</span>\n          </div>\n        </div>\n        <div class=\"feature-sep features-loop\"></div>\n        <div class=\"feature-item features-loop\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:truck\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Free Shipping</span>\n            <span class=\"feature-sub\">Orders above &#8377;5,000</span>\n          </div>\n        </div>\n        <div class=\"feature-sep features-loop\"></div>\n        <div class=\"feature-item features-loop\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:refresh-cw\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Easy Returns</span>\n            <span class=\"feature-sub\">15-day hassle-free</span>\n          </div>\n        </div>\n        <div class=\"feature-sep features-loop\"></div>\n        <div class=\"feature-item features-loop\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:award\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Award-Winning Craft</span>\n            <span class=\"feature-sub\">Ministry of Textiles recognized</span>\n          </div>\n        </div>\n        <div class=\"feature-sep features-loop\"></div>\n        <div class=\"feature-item features-loop\">\n          <div class=\"feature-icon-wrap\">\n            <iconify-icon icon=\"lucide:headphones\" style=\"font-size: 20px; color: #e8bf6a\"></iconify-icon>\n          </div>\n          <div class=\"feature-text\">\n            <span class=\"feature-title\">Concierge Support</span>\n            <span class=\"feature-sub\">Personal styling guidance</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </body>\n</html>",
        "custom_class": ""
      }
    },
