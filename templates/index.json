    "custom_liquid_HnjQAw": {
      "type": "custom-liquid",
      "name": "Custom liquid",
      "settings": {
        "custom_liquid": "<style>\n.custom-feature-grid__wrapper {\n  background: #fff;\n  padding: 50px 30px;\n}\n\n.custom-feature-grid__wrapper {\n  max-width: 1400px;\n  margin: 0 auto;\n  display: flex;\n  justify-content: center;\n  align-items: flex-start;\n  gap: 60px;\n}\n\n.custom-feature-item {\n  flex: 1;\n  text-align: center;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.custom-feature-item svg {\n  width: 36px;\n  height: 36px;\n  margin: 0 auto 24px;\n  display: block;\n  stroke: #c8a46a;\n}\n\n.custom-feature-item h3 {\n  margin: 0 0 15px;\n  font-size: 24px;\n  line-height: 1.3;\n  font-weight: 400;\n  color: #1d1d1d;\n  text-align: center;\n}\n\n.custom-feature-item p {\n  margin: 0 auto 20px;\n  max-width: 320px;\n  font-size: 14px;\n  line-height: 1.7;\n  color: #666;\n  text-align: center;\n}\n\n.custom-feature-item a {\n  display: inline-block;\n  font-size: 13px;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n  color: #d65d2e;\n  text-decoration: none;\n  font-weight: 600;\n}\n\n.custom-feature-item a:hover {\n  opacity: 0.8;\n}\n\n/* Tablet */\n@media screen and (max-width: 991px) {\n  .custom-feature-grid__wrapper {\n    gap: 30px;\n  }\n\n  .custom-feature-item h3 {\n    font-size: 1.75rem;\n  }\n\n  .custom-feature-item p {\n    font-size: 0.95rem;\n  }\n}\n\n/* Mobile */\n@media screen and (max-width: 767px) {\n  .custom-feature-grid {\n    padding: 40px 20px;\n  }\n\n  .custom-feature-grid__wrapper {\n    flex-direction: column;\n    align-items: center;\n    gap: 40px;\n  }\n\n  .custom-feature-item {\n    width: 100%;\n    max-width: 400px;\n  }\n\n  .custom-feature-item svg {\n    width: 32px;\n    height: 32px;\n    margin-bottom: 16px;\n  }\n\n  .custom-feature-item h3 {\n    font-size: 22px;\n    margin-bottom: 12px;\n  }\n\n  .custom-feature-item p {\n    max-width: 100%;\n    font-size: 0.9375rem;\n    margin-bottom: 16px;\n  }\n\n  .custom-feature-item a {\n    font-size: 0.8125rem;\n  }\n}\n</style>\n\n<div class=\"custom-feature-grid\">\n  <div class=\"custom-feature-grid__wrapper\">\n\n    <div class=\"custom-feature-item\">\n      <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\"\n          d=\"M9 3h6m-3 0v4m-4 4h8m-9 10h10a2 2 0 002-2V9l-3-4H8L5 9v10a2 2 0 002 2z\" />\n      </svg>\n\n      <h3>Authentic & Handcrafted</h3>\n\n      <p>\nHandcrafted by skilled artisans using\ntraditional techniques.\n      </p>\n\n      <a href=\"/collections/all\">EXPLORE CRAFTS</a>\n    </div>\n\n    <div class=\"custom-feature-item\">\n      <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\"\n          d=\"M12 2l2.2 4.5L19 7l-3.5 3.4.8 4.8L12 13l-4.3 2.2.8-4.8L5 7l4.8-.5L12 2z\" />\n      </svg>\n\n      <h3>Curated for Every Occasion</h3>\n\n      <p>\nElegant sarees and ethnic wear\nfor every moment.\n      </p>\n\n      <a href=\"/pages/contact\">SHOP COLLECTIONS</a>\n    </div>\n\n    <div class=\"custom-feature-item\">\n      <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\"\n          d=\"M21 15.5v3a2 2 0 01-2.2 2A19.8 19.8 0 013.5 5.2 2 2 0 015.5 3h3a2 2 0 012 1.7l.5 3a2 2 0 01-.6 1.8l-1.2 1.2a16 16 0 006.1 6.1l1.2-1.2a2 2 0 011.8-.6l3 .5A2 2 0 0121 15.5z\" />\n      </svg>\n\n      <h3>Here to Help, Always</h3>\n\n      <p>\nExpert support to help you choose </br>\nwhat's perfect for you.\n      </p>\n\n      <a href=\"/pages/contact\">CONTACT US</a>\n    </div>\n\n  </div>\n</div>",
